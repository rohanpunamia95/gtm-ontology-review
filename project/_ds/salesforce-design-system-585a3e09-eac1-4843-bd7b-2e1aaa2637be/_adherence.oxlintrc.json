        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|success|warning|error)$/]",
        "message": "<Toast> tone must be one of 'info' | 'success' | 'warning' | 'error'."
